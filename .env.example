# Convex CLI — used by `pnpm convex dev` to push schema/functions
# Get this value from the existing v1 project's .env.local OR by running
# `npx convex dev` once interactively and selecting "existing deployment".
CONVEX_DEPLOYMENT=

# Public Convex URL used by browser/mobile clients. Format:
#   https://<deployment-name>.convex.cloud
# After `npx convex dev` runs once, find this in .env.local or the Convex dashboard.
NEXT_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_CONVEX_URL=

# Server-only secrets. Never expose these through mobile or web clients.
GEMINI_API_KEY=
RESEND_API_KEY=
WHATSAPP_PROVIDER_API_KEY=
PAYSTACK_SECRET_KEY=
STRIPE_SECRET_KEY=
OZOW_SECRET_KEY=
