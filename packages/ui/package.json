{
  "name": "@batho/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./theme/init-script": {
      "types": "./src/theme/init-script.ts",
      "default": "./src/theme/init-script.ts"
    },
    "./native": {
      "types": "./src/native/index.ts",
      "default": "./src/native/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist coverage",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@batho/design-tokens": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "expo-secure-store": "*"
  },
  "peerDependenciesMeta": {
    "react-dom": { "optional": true },
    "expo-secure-store": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.1.17",
    "@types/react-dom": "~19.1.11",
    "expo-secure-store": "~15.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
